{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.hamsterCrumbs.hamstoolbox",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.*"
  ],
  "modes": {
    "window": {
      "title": "Ham's Toolbox",
      "width": 800,
      "height": 600,
      "minWidth": 400,
      "minHeight": 300,
      "center": true,
      "resizable": true
    }
  },
  "cli": {
    "binaryName": "hams-toolbox",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "frontendLibrary": {
      "initCommand": "npm install",
      "devCommand": "npm run dev",
      "buildCommand": "npm run build",
      "projectPath": "/",
      "devUrl": "http://localhost:5173"
    },
    "binaryVersion": "6.7.0"
  }
}